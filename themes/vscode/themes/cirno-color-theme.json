  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#5f7299", "fontStyle": "italic" }
    },
    {
      "name": "Variables, identifiers",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": { "foreground": "#d4e4f5" }
    },
    {
      "name": "Variable members / properties",
      "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key", "support.variable.property"],
      "settings": { "foreground": "#6fb2ee" }
    },
    {
      "name": "Language built-in / this",
      "scope": ["variable.language", "variable.language.this", "support.type.object.module"],
      "settings": { "foreground": "#5fccc6", "fontStyle": "italic" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#9fb6f2", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator", "punctuation.definition.parameters"],
      "settings": { "foreground": "#a3b6d2" }
    },
    {
      "name": "Punctuation tags / brackets in markup",
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#536b91" }
    },
    {
      "name": "Constants & numbers",
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other", "keyword.other.unit", "support.constant"],
      "settings": { "foreground": "#eca06a" }
    },
    {
      "name": "Escape characters",
      "scope": ["constant.character.escape", "constant.other.placeholder"],
      "settings": { "foreground": "#5fccc6" }
    },
    {
      "name": "Strings",
      "scope": ["string", "punctuation.definition.string", "string.quoted"],
      "settings": { "foreground": "#84ddb2" }
    },
    {
      "name": "Regex",
      "scope": ["string.regexp", "constant.other.character-class.regexp"],
      "settings": { "foreground": "#5fccc6" }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "keyword.control", "storage.type.function.arrow"],
      "settings": { "foreground": "#b78ee2" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical"],
      "settings": { "foreground": "#6fb2ee" }
    },
    {
      "name": "Storage / modifiers",
      "scope": ["storage", "storage.type", "storage.modifier", "keyword.other"],
      "settings": { "foreground": "#b78ee2", "fontStyle": "italic" }
    },
    {
      "name": "Functions & methods",
      "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "variable.function"],
      "settings": { "foreground": "#7ad6f0" }
    },
    {
      "name": "Types, classes, namespaces",
      "scope": ["entity.name.type", "entity.name.class", "entity.name.namespace", "support.type", "support.class", "entity.other.inherited-class", "entity.name.type.class"],
      "settings": { "foreground": "#e8cd86" }
    },
    {
      "name": "Decorators / annotations",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator", "meta.annotation"],
      "settings": { "foreground": "#5fccc6", "fontStyle": "italic" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag", "meta.tag.sgml", "support.class.component"],
      "settings": { "foreground": "#ec5a72" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name", "meta.attribute"],
      "settings": { "foreground": "#e8cd86", "fontStyle": "italic" }
    },
    {
      "name": "Preprocessor / macros",
      "scope": ["meta.preprocessor", "keyword.control.directive", "entity.name.function.preprocessor"],
      "settings": { "foreground": "#5fccc6" }
    },
    {
      "name": "Markup heading",
      "scope": ["markup.heading", "entity.name.section", "markup.heading entity.name"],
      "settings": { "foreground": "#7ad6f0", "fontStyle": "bold" }
    },
    {
      "name": "Markup bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": { "foreground": "#eca06a", "fontStyle": "bold" }
    },
    {
      "name": "Markup italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": { "foreground": "#b78ee2", "fontStyle": "italic" }
    },
    {
      "name": "Markup quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#5f7299", "fontStyle": "italic" }
    },
    {
      "name": "Markup links",
      "scope": ["markup.underline.link", "string.other.link", "constant.other.reference.link"],
      "settings": { "foreground": "#3aa9dd", "fontStyle": "underline" }
    },
    {
      "name": "Markup inline / raw code",
      "scope": ["markup.inline.raw", "markup.raw.block", "markup.fenced_code.block"],
      "settings": { "foreground": "#84ddb2" }
    },
    {
      "name": "Markup list bullet",
      "scope": ["markup.list punctuation.definition.list.begin", "punctuation.definition.list"],
      "settings": { "foreground": "#7ad6f0" }
    },
    {
      "name": "Markup inserted",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#84ddb2" }
    },
    {
      "name": "Markup deleted",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ec5a72" }
    },
    {
      "name": "Markup changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#e8cd86" }
    },
    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json", "support.type.property-name.json punctuation"],
      "settings": { "foreground": "#7ad6f0" }
    },
    {
      "name": "YAML keys",
      "scope": ["entity.name.tag.yaml", "support.type.property-name.yaml"],
      "settings": { "foreground": "#7ad6f0" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#ec5a72", "fontStyle": "underline" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#eca06a", "fontStyle": "strikethrough" }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#9fb6f2",
    "property": "#6fb2ee",
    "variable.readonly": "#eca06a",
    "function": "#7ad6f0",
    "method": "#7ad6f0",
    "class": "#e8cd86",
    "interface": "#e8cd86",
    "enum": "#e8cd86",
    "enumMember": "#eca06a",
    "type": "#e8cd86",
    "typeParameter": "#5fccc6",
    "namespace": "#5fccc6",
    "macro": "#5fccc6",
    "*.declaration": { "fontStyle": "bold" },
    "*.deprecated": { "fontStyle": "strikethrough" }
  }
}
